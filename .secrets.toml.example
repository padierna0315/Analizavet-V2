# Ejemplo de configuración de secretos
# Copiar este archivo a .secrets.toml y rellenar con tus valores reales

[default]
REDIS_URL = "redis://localhost:6379/0"
APPSHEET_API_KEY = "tu-api-key-aqui"
APPSHEET_APP_ID = "tu-app-id-aqui"
APPSHEET_TABLE_NAME = "Muestras_Activas"

# NOTA: Nunca subir .secrets.toml a GitHub
# Este archivo está en .gitignore